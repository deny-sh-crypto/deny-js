{
  "name": "deny-sh",
  "version": "1.0.0",
  "description": "Deniable encryption. One ciphertext, two passwords, two completely different plaintexts.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "bin": {
    "deny-sh": "dist/src/cli.js"
  },
  "files": [
    "dist/src/index.js",
    "dist/src/index.d.ts",
    "dist/src/core.js",
    "dist/src/core.d.ts",
    "dist/src/cli.js",
    "dist/src/cli.d.ts",
    "dist/src/commands/**/*.js",
    "dist/src/commands/**/*.d.ts",
    "dist/src/utils/**/*.js",
    "dist/src/utils/**/*.d.ts",
    "README.md",
    "LICENSE",
    "COMMERCIAL-LICENSE.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test $(ls dist/src/test/*.test.js | grep -v verification.test.js)",
    "test:all": "node --test dist/src/test/*.test.js",
    "test:verification": "node --test dist/src/test/verification.test.js",
    "verify": "npm run build && node run-verification.mjs",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "encryption",
    "deniable",
    "plausible-deniability",
    "aes-256",
    "scrypt",
    "privacy",
    "cryptography",
    "duress",
    "control-file"
  ],
  "homepage": "https://deny.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/deny-sh-crypto/deny-js"
  },
  "bugs": {
    "url": "https://github.com/deny-sh-crypto/deny-js/issues"
  },
  "author": "deny.sh",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "typescript": "^5.9.3"
  }
}
